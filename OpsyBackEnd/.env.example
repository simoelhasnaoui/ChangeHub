APP_NAME=ChangeHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# For real Gmail inboxes: use smtp + a real sender (Gmail App Password or transactional provider).
# Default "log" only writes to storage/logs — you will NOT receive mail in Gmail.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_ENCRYPTION=tls
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Example — Gmail SMTP (use an App Password, not your normal password):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM_ADDRESS=you@gmail.com
# MAIL_FROM_NAME="ChangeHub"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# GitHub OAuth (Implementer repo listing)
# Create a GitHub OAuth App and set its callback URL to:
#   GITHUB_REDIRECT_URI (must match exactly)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost/api/github/link/callback
GITHUB_FRONTEND_REDIRECT=http://localhost:5173/implementer/github

# SPA URL (no trailing slash) — notification links, OAuth return, and password reset e-mail link (/reset-password?...).
FRONTEND_URL=http://localhost:5173

# Google OAuth (Gmail notification mirror for all users). Callback URL in Google Cloud Console:
#   {APP_URL}/api/google/link/callback  → must match GOOGLE_REDIRECT_URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/google/link/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/oauth/google
